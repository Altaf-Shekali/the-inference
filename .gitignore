node_modules
dist
.DS_Store
.env

# local-only Claude Code settings (per-machine, never commit)
.claude/settings.local.json

# API keys & credentials — never commit
pipeline/pexels.key
pipeline/nemotron.key
pipeline/tavily.key
pipeline/gemini.key

# Per-channel YouTube secrets — keep the folder, ignore the tokens + clients
pipeline/channels/*/youtube.token.json
pipeline/channels/*/youtube.client.json
pipeline/youtube.client.json
pipeline/youtube.token.json

# Ignore the output video from Git but not videos you import into src/.
out

# Kokoro local TTS — Python venv + large model files (re-creatable, see README)
pipeline/.venv-tts
pipeline/kokoro/*.onnx
pipeline/kokoro/*.bin

# ---- extra safety for the PUBLIC repo: never commit any key/token/secret ----
**/*.key
**/youtube.client.json
**/youtube.token.json
*.local.txt
pipeline/github-secrets.local.txt

# ---- generated render media — regenerated every run; keep it OUT of the repo ----
# (fonts + quiz sounds under public/ stay committed; only these two are generated)
public/vo/
public/broll/
